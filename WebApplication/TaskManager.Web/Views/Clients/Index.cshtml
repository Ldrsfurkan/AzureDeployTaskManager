@model ClientsViewModel

<div class="container mt-4">
    <div class="row">

        <!-- CLIENT LIST -->
        <div class="col-md-4">

            <div class="card shadow-sm">
                <div class="card-header bg-dark text-white">
                    Clients
                </div>

                <ul class="list-group list-group-flush">

                    @foreach (var client in Model.Clients)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">

                            <a asp-controller="Clients"
                               asp-action="Index"
                               asp-route-clientId="@client.Id"
                               class="text-decoration-none">
                                @client.Name
                            </a>
                        </li>
                    }

                </ul>
            </div>

        </div>


        <!-- DUTIES -->
        <div class="col-md-8">

            <div class="card shadow-sm">

                <div class="card-header bg-primary text-white">
                    Client Duties
                </div>

                <div class="card-body">

                    @if (Model.Duties.Any())
                    {
                        <table class="table table-hover">

                            <thead>
                                <tr>
                                    <th>Description</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var duty in Model.Duties)
                                {
                                    <tr>
                                        <td>@duty.Description</td>
                                        <td>
                                            <span class="badge bg-info">
                                                @duty.Status
                                            </span>
                                        </td>
                                        <td>@duty.CreatedAt.ToString("dd-MM-yyyy HH:mm")</td>
                                    </tr>
                                }

                            </tbody>

                        </table>
                    }
                    else
                    {
                        <div class="text-muted">
                            Select a client to view duties
                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>