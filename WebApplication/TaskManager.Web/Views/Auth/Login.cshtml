<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Login - Duty</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #ffffff;
            margin: 0;
            padding: 0;
        }

        .login-box {
            border: 1px solid #007bff;
            width: 300px;
            margin: 50px auto;
            padding: 30px;
            border-radius: 10px;
            text-align: center;
        }

            .login-box h2 {
                color: #007bff;
            }

            .login-box input[type="text"],
            .login-box input[type="password"] {
                width: 90%;
                padding: 10px;
                margin: 10px 0;
                border-radius: 20px;
                border: 1px solid #000;
            }

            .login-box button {
                width: 95%;
                padding: 10px;
                border-radius: 20px;
                border: none;
                background: linear-gradient(to right, #6a5af9, #f55ca2);
                color: #000;
                font-weight: bold;
                cursor: pointer;
            }

            .login-box a {
                text-decoration: none;
                color: #0000ff;
            }

            .login-box p {
                margin-top: 15px;
            }
    </style>
</head>
<body>
    <div class="login-box">
        <h2>Login</h2>
        <form asp-action="Login" method="post">
            <input type="text" name="Username" placeholder="Username" />
            <input type="password" name="Password" placeholder="Password" />
            <button type="submit">Login</button>
            <p>Hesabın yok mu? <a href="@Url.Action("register")">Register</a></p>
        </form>
    </div>
</body>
</html>