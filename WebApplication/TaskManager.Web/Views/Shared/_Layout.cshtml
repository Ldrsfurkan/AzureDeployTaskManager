<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskManager.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <header>
            <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-4">
                <div class="container-fluid">

                    <a class="navbar-brand fw-bold" asp-area="" asp-controller="Duty" asp-action="GetDuties">TaskManager</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                        <ul class="navbar-nav flex-grow-1">
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Admin" asp-action="Dashboard">Admin Panel</a>
                                </li>
                            }
                            @if (User.IsInRole("Admin") || User.IsInRole("Employee"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white" asp-area="" asp-controller="Duty" asp-action="MyTasks">My Tasks</a>
                                </li>
                            }
                        </ul>

                        <ul class="navbar-nav ms-auto align-items-center">
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown">
                                    <a class="nav-link position-relative" href="#" id="auditLogDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="bi bi-bell-fill fs-5 text-light hover-opacity"></i>
                                        <span class="position-absolute top-25 start-75 translate-middle p-1 bg-danger border border-primary rounded-circle">
                                            <span class="visually-hidden">New alerts</span>
                                        </span>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-2" aria-labelledby="auditLogDropdown" id="auditLogMenu" style="width: 320px; max-height: 400px; overflow-y: auto;">
                                        <li><span class="dropdown-item text-muted text-center py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Loading...</span></li>
                                    </ul>
                                </li>
                            }
                            @if (User.Identity is { IsAuthenticated: true })
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-white btn btn-sm btn-danger px-3 fw-bold shadow-sm" asp-area="" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i> Logout
                                    </a>
                                </li>
                            }
                        </ul>

                    </div>
                </div>
            </nav>
        </header>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer bg-primary text-white">
        <div class="container">
            &copy; 2026 - TaskManager
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<script>
    $(document).ready(function () {
        // Fetch logs only when the bell icon is clicked
        $('#auditLogDropdown').on('click', function () {
            var menu = $('#auditLogMenu');

            // Show loading spinner initially
            menu.html('<li><span class="dropdown-item text-muted text-center py-3"><div class="spinner-border spinner-border-sm text-primary" role="status"></div> Loading logs...</span></li>');

            $.get('/admin/recent-logs', function (data) {
                menu.empty(); // Clear loading text

                // Header for the dropdown
                menu.append('<li><h6 class="dropdown-header text-uppercase fw-bold text-primary bg-light pb-2">Recent Activities</h6></li>');

                if (data.length === 0) {
                    menu.append('<li><span class="dropdown-item text-muted small py-3 text-center">No recent activity found.</span></li>');
                    return;
                }

                // Create a notification card for each log
                data.forEach(function (log) {
                    // Format the date nicely
                    var date = new Date(log.timestamp).toLocaleString([], { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });

                    var item = `
                        <li>
                            <div class="dropdown-item border-bottom py-2" style="white-space: normal;">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="fw-bold text-dark" style="font-size: 0.85rem;">${log.action}</span>
                                    <small class="text-muted" style="font-size: 0.7rem;">${date}</small>
                                </div>
                                <div class="text-secondary" style="font-size: 0.8rem; line-height: 1.2;">
                                    ${log.details}
                                </div>
                            </div>
                        </li>`;
                    menu.append(item);
                });
            }).fail(function() {
                menu.html('<li><span class="dropdown-item text-danger small py-3 text-center">Failed to load logs.</span></li>');
            });
        });
    });
</script>
