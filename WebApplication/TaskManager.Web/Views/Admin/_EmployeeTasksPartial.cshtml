@using BuildingBlocks.Contracts.DutyContracts
@model IEnumerable<DutyDto>

@if (!Model.Any())
{
    <div class="alert alert-info shadow-sm" role="alert">
        This employee currently has no assigned tasks.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var duty in Model)
        {
            string badgeClass = duty.Status switch
            {
                "TAMAMLANDI" => "bg-success",
                "DEVAM_EDIYOR" => "bg-primary",
                "YANIT_BEKLENIYOR" => "bg-info text-dark",
                "KULLANCI_ONAYI_BEKLENIYOR" => "bg-warning text-dark",
                "TEST_BEKLENIYOR" => "bg-warning text-dark",
                "IPTAL_EDILDI" => "bg-danger",
                _ => "bg-dark"
            };

            string borderClass = duty.Status switch
            {
                "TAMAMLANDI" => "border-success",
                "DEVAM_EDIYOR" => "border-primary",
                "YANIT_BEKLENIYOR" => "border-info",
                "KULLANCI_ONAYI_BEKLENIYOR" => "border-warning",
                "TEST_BEKLENIYOR" => "border-warning",
                "IPTAL_EDILDI" => "border-danger",
                _ => "border-dark"
            };

            <div class="col">
                <div class="card h-100 shadow-sm border-top-0 border-end-0 border-bottom-0 border-start border-4 @borderClass">
                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge rounded-pill @badgeClass px-3 py-2">@duty.Status</span>
                            <span class="badge bg-light text-dark border">Priority: @duty.Priority</span>
                        </div>
                        <h5 class="card-title fw-bold mt-2">@duty.Description</h5>
                        <p class="card-text text-muted small mb-3">@duty.Description</p>
                        <div class="mt-auto">
                            <hr class="text-muted opacity-25">
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted fw-bold">Client: @duty.ClientName</small>
                                <small class="text-muted">@duty.CreatedAt.ToString("dd MMM yyyy")</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}